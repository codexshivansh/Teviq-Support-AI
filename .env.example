PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://demo-client-site.com,https://teviq-support-ai-dashboard-ph9p.vercel.app,https://teviq.in,https://www.teviq.in

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

CLERK_SECRET_KEY=your_clerk_secret_key
ENABLE_DEMO_LOGIN=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SHOPIFY_CREDENTIALS_SECRET=use_a_long_random_secret_for_shopify_token_encryption
SHOPIFY_CLIENT_ID=your_shopify_app_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_app_client_secret
SHOPIFY_SCOPES=read_products,read_orders
SHOPIFY_ADMIN_API_VERSION=2026-07
SHOPIFY_REDIRECT_URI=https://teviq-support-ai-backend.onrender.com/api/integrations/shopify/oauth/callback
PUBLIC_API_URL=https://teviq-support-ai-backend.onrender.com
DASHBOARD_URL=https://dashboard.teviq.in

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

INTERNAL_CRON_SECRET=use_a_long_random_secret_for_the_internal_cron_endpoint
